  "visual_patterns": {
    "backgrounds": [
      {
        "name": "dark_navy",
        "description": "Fundo escuro principal dos posts",
        "css": "background: #0D1817;",
        "usage": "Posts informativos, carrosseis educativos"
      },
      {
        "name": "dark_blue",
        "description": "Fundo azul escuro com profundidade",
        "css": "background: #121426;",
        "usage": "Posts de destaque, lancamentos"
      },
      {
        "name": "blue_circle",
        "description": "Circulo azul grande como elemento de fundo",
        "css": "background: radial-gradient(circle at center, #1B6BC5 0%, #033860 60%, #0D1817 100%);",
        "usage": "Posts de impacto, headlines fortes"
      },
      {
        "name": "split_layout",
        "description": "Foto no topo, conteudo claro embaixo",
        "css_top": "background-image: url(...); background-size: cover;",
        "css_bottom": "background: linear-gradient(180deg, #D6EBFF, #FFFFFF);",
        "usage": "Posts explicativos, antes/depois"
      }
    ],
    "accent_elements": [
      {
        "name": "green_bar_top",
        "description": "Barra verde fina no topo do post",
        "css": "height: 6px; background: linear-gradient(90deg, #2A7221, #6ED161);",
        "usage": "Todos os posts - marca registrada visual"
      },
      {
        "name": "green_side_strip",
        "description": "Faixa verde vertical na lateral esquerda",
        "css": "width: 8px; height: 100%; background: #6ED161; position: absolute; left: 0;",
        "usage": "Posts de destaque, alertas"
      },
      {
        "name": "green_cta_button",
        "description": "Botao CTA verde com seta",
        "css": "background: #2A7221; color: #FFFFFF; padding: 14px 28px; border-radius: 12px; font-weight: 700;",
        "usage": "Call-to-action principal"
      }
    ],
    "decorative": [
      {
        "name": "glow_blob",
        "description": "Blob difuso de cor no fundo",
        "css": "width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(37, 99, 235, 0.15) 0%, transparent 70%); position: absolute;",
        "usage": "Adicionar profundidade ao fundo escuro"
      },
      {
        "name": "grid_lines",
        "description": "Linhas sutis de grid no fundo",
        "css": "opacity: 0.03; background: #FFFFFF;",
        "usage": "Textura sutil em fundos escuros"
      }
    ],
    "cards": {
      "dark_card": {
        "css": "background: rgba(37, 99, 235, 0.08); border: 1px solid rgba(59, 130, 246, 0.2); border-radius: 16px; padding: 24px 28px;"
      },
      "highlight_card": {
        "css": "background: rgba(106, 209, 97, 0.1); border: 1px solid rgba(106, 209, 97, 0.3); border-radius: 16px; padding: 24px 28px;"
      },
      "light_card": {
        "css": "background: #FFFFFF; border-radius: 16px; padding: 24px 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.08);"
      }
    }
  },
  "layout_rules": {
    "canvas": {
      "feed": { "width": 1080, "height": 1080 },
      "story": { "width": 1080, "height": 1920 },
      "carousel": { "width": 1080, "height": 1080 }
    },
    "padding": {
      "outer": "56px",
      "inner": "28px",
      "between_sections": "32px"
    },
    "common_structures": [
      "accent_bar + header_tag + headline + cards + footer",
      "accent_bar + photo_half + content_half_light",
      "logo_top + circle_bg + bold_headline + illustration"
    ]
  },
  "content_style": {
    "headline_style": "Bold, direto, uppercase. Usa palavras de impacto. Fala com o importador.",
